# ============================================================
# ACL 1 — Bloquer Marketing (VLAN 20) -> Serveurs (VLAN 30)
# Equipement : Routeur (inter-VLAN routing)
# Appliquer sur la sous-interface du VLAN 30 en direction IN
# ============================================================

en
conf t

ip access-list standard BLOCK_MARKETING
 deny   192.168.20.0 0.0.0.255
 permit any

! Appliquer sur la sous-interface VLAN 30 (côté serveurs)
interface GigabitEthernet0/0.30
 ip access-group BLOCK_MARKETING in

end
write memory

! Vérification
show ip access-lists BLOCK_MARKETING
show ip interface GigabitEthernet0/0.30
