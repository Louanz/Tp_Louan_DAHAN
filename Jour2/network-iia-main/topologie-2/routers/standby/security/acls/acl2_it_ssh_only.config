# ============================================================
# ACL 2 — Autoriser seulement IT (VLAN 21) en SSH vers Serveurs (VLAN 30)
# Equipement : Routeur (inter-VLAN routing)
# Appliquer sur la sous-interface du VLAN 30 en direction IN
# ============================================================

en
conf t

ip access-list extended IT_SSH_ONLY
 ! Autoriser IT à faire du SSH vers les serveurs
 permit tcp 192.168.21.0 0.0.0.255 192.168.30.0 0.0.0.255 eq 22
 ! Bloquer tout autre trafic vers les serveurs
 deny   ip any 192.168.30.0 0.0.0.255
 ! Autoriser le reste du trafic
 permit ip any any

! Appliquer sur la sous-interface VLAN 30 (côté serveurs)
interface GigabitEthernet0/0.30
 ip access-group IT_SSH_ONLY in

end
write memory

! Vérification
show ip access-lists IT_SSH_ONLY
show ip interface GigabitEthernet0/0.30
