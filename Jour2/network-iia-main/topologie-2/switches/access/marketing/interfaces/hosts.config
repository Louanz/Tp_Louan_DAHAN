# Mode initial : User EXEC
# Passage en mode Privileged EXEC via enable (droit de lecture)
# Passage en mode Global COnfiguration via conf t (droit de modifier)

en
conf t
hostname SW-Marketing

interface range fastEthernet 0/1-3
# interface fastEthernet 0/1 pour juste 1 interface
    switchport mode access
    switchport access vlan 20
    no shutdown
exit
end
write memory
sh int
